@UTF8
@Begin
@Languages:	eng
@Participants:	SPK Speaker, LSN Adult
@Options:	CA
@ID:	eng|corpus|SPK|||||Speaker|||
@ID:	eng|corpus|LSN|||||Adult|||
@Comment:	CA intonation contour markers and CA terminators
@Comment:	Constructs: rising_to_high, rising_to_mid, level_pitch,
	falling_to_mid, falling_to_low, ca_no_break, ca_technical_break,
	ca_no_break_linker, ca_technical_break_linker, unmarked_ending
*SPK:	rising to high ⇗
*SPK:	rising to mid ↗
*SPK:	level pitch →
*SPK:	falling to mid ↘
*SPK:	falling to low ⇘
*SPK:	no break continuation ⇘ ≈
*LSN:	+≈ continuing here .
*SPK:	technical break continuation ⇗ ≋
*LSN:	+≋ continuing here .
*SPK:	unmarked ending ∞
@End
