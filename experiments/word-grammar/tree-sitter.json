{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "talkbank",
      "camelcase": "TalkBank",
      "title": "TalkBank CHAT",
      "scope": "source.talkbank",
      "file-types": [
        "cha"
      ],
      "injection-regex": "^talkbank$",
      "class-name": "TreeSitterTalkbank"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "BSD-3-Clause",
    "description": "TalkBank CHAT transcription format",
    "authors": [
      {
        "name": "Franklin Chen",
        "email": "franklinchen@franklinchen.com",
        "url": "https://franklinchen.com"
      }
    ],
    "links": {
      "repository": "https://github.com/TalkBank/tree-sitter-talkbank",
      "funding": "https://talkbank.org"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
