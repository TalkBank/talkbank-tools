{
  "name": "tree-sitter-talkbank",
  "version": "0.1.0",
  "description": "TalkBank CHAT transcription format",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TalkBank/tree-sitter-talkbank.git"
  },
  "homepage": "https://talkbank.org",
  "bugs": {
    "url": "https://github.com/TalkBank/tree-sitter-talkbank/issues"
  },
  "funding": "https://talkbank.org",
  "license": "BSD-3-Clause",
  "author": {
    "name": "Franklin Chen",
    "email": "franklinchen@franklinchen.com",
    "url": "https://franklinchen.com"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "talkbank"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.7.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.8"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
