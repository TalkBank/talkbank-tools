# Source and dev-only files
src/**
tests/**
coverage/**
book/**

# All node_modules are bundled into dist/extension.js; ship none of them.
node_modules/**

# tsc output — dist/extension.js is the shipped entry; only webview assets
# (which live outside the esbuild bundle) need to ride along from out/.
out/*.js
out/*.js.map
out/*/
!out/webview/

# Build config
tsconfig.json
eslint.config.js
vitest.config.ts
esbuild.config.mjs

# Developer docs (keep readme.md and images/, those are shown in Marketplace)
CLAUDE.md
DEVELOPER.md
CLAN-FEATURES.md
GUIDE.md
.gitignore
.vscodeignore

# Build scripts run before packaging, not needed at runtime
scripts/**

# Placeholder that keeps server/ in git but should not ship in the VSIX
server/.gitignore

# Leftover VSIX files from prior local packaging runs
*.vsix

# Runtime does not need the lockfile; shipping it was 3.2 MB of bloat per VSIX
package-lock.json
