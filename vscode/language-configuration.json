{
  "comments": {
    "lineComment": "@Comment:\t"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"],
    ["\"", "\""]
  ],
  "wordPattern": "[\\w'@%*+&\\-]+",
  "indentationRules": {
    "increaseIndentPattern": "^[*%]\\w+:\\t",
    "decreaseIndentPattern": "^[@*%]"
  }
}
