{
  "CHAT File Header": {
    "prefix": ["@UTF8", "header", "newfile"],
    "body": [
      "@UTF8",
      "@Begin",
      "@Languages:\t${1:eng}",
      "@Participants:\t${2:CHI} ${3:Target_Child}, ${4:MOT} ${5:Mother}",
      "@ID:\t${1:eng}|${6:corpus}|${2:CHI}|${7:}|${8:}|||${3:Target_Child}|||",
      "@ID:\t${1:eng}|${6:corpus}|${4:MOT}|||||${5:Mother}|||",
      "*${2:CHI}:\t$0",
      "@End"
    ],
    "description": "Complete CHAT file header block with @UTF8, @Begin, participants, and @ID lines"
  },
  "Add Participant": {
    "prefix": ["@Participants", "participant"],
    "body": [
      "@Participants:\t${1:CHI} ${2:Target_Child}, ${3:MOT} ${4:Mother}"
    ],
    "description": "@Participants header with two speakers"
  },
  "ID Header": {
    "prefix": ["@ID", "id"],
    "body": [
      "@ID:\t${1:eng}|${2:corpus}|${3:CHI}|${4:}|${5:}|||${6:Target_Child}|||"
    ],
    "description": "@ID header line (language|corpus|code|age|sex|||role|||)"
  },
  "Main Tier": {
    "prefix": ["*", "utterance"],
    "body": [
      "*${1:CHI}:\t${0} ."
    ],
    "description": "Main tier utterance line"
  },
  "Dependent Tier - Mor": {
    "prefix": ["%mor"],
    "body": [
      "%mor:\t$0"
    ],
    "description": "%mor dependent tier (morphosyntax)"
  },
  "Dependent Tier - Gra": {
    "prefix": ["%gra"],
    "body": [
      "%gra:\t$0"
    ],
    "description": "%gra dependent tier (grammatical relations)"
  },
  "Comment": {
    "prefix": ["@Comment", "comment"],
    "body": [
      "@Comment:\t$0"
    ],
    "description": "@Comment header"
  },
  "Gem": {
    "prefix": ["@Bg", "@Eg", "gem"],
    "body": [
      "@Bg:\t${1:Activity}",
      "$0",
      "@Eg:\t${1:Activity}"
    ],
    "description": "Gem block (@Bg/@Eg pair)"
  }
}
