{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CHAT",
  "scopeName": "source.chat",
  "patterns": [
    {
      "include": "#headers"
    },
    {
      "include": "#main-tier"
    },
    {
      "include": "#dependent-tiers"
    },
    {
      "include": "#comments"
    }
  ],
  "repository": {
    "headers": {
      "patterns": [
        {
          "name": "meta.header.required.chat",
          "match": "^(@(UTF8|Begin|End))\\b",
          "captures": {
            "1": { "name": "keyword.control.header.chat" }
          }
        },
        {
          "name": "meta.header.important.chat",
          "match": "^(@(Languages|Participants|ID|Birth of [A-Z]+))(:)(.*)",
          "captures": {
            "1": { "name": "keyword.control.header.chat" },
            "3": { "name": "punctuation.separator.header.chat" },
            "4": { "name": "string.unquoted.header-value.chat" }
          }
        },
        {
          "name": "meta.header.general.chat",
          "match": "^(@[A-Za-z][A-Za-z0-9 ]*?)(:)(.*)",
          "captures": {
            "1": { "name": "entity.name.tag.header.chat" },
            "2": { "name": "punctuation.separator.header.chat" },
            "3": { "name": "string.unquoted.header-value.chat" }
          }
        }
      ]
    },
    "main-tier": {
      "patterns": [
        {
          "name": "meta.main-tier.chat",
          "begin": "^(\\*[A-Z0-9]{2,3})(:)(\\t)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "entity.name.function.speaker.chat" },
            "2": { "name": "punctuation.separator.tier.chat" },
            "3": { "name": "punctuation.whitespace.tab.chat" }
          },
          "patterns": [
            {
              "include": "#utterance-content"
            }
          ]
        }
      ]
    },
    "dependent-tiers": {
      "patterns": [
        {
          "name": "meta.dependent-tier.mor.chat",
          "begin": "^(%mor)(:)(\\t)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.tier.mor.chat" },
            "2": { "name": "punctuation.separator.tier.chat" },
            "3": { "name": "punctuation.whitespace.tab.chat" }
          },
          "patterns": [
            {
              "include": "#mor-content"
            }
          ]
        },
        {
          "name": "meta.dependent-tier.gra.chat",
          "begin": "^(%gra)(:)(\\t)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.tier.gra.chat" },
            "2": { "name": "punctuation.separator.tier.chat" },
            "3": { "name": "punctuation.whitespace.tab.chat" }
          },
          "patterns": [
            {
              "include": "#gra-content"
            }
          ]
        },
        {
          "name": "meta.dependent-tier.general.chat",
          "begin": "^(%[a-z]{2,})(:)(\\t)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.tier.chat" },
            "2": { "name": "punctuation.separator.tier.chat" },
            "3": { "name": "punctuation.whitespace.tab.chat" }
          },
          "patterns": [
            {
              "include": "#tier-content"
            }
          ]
        }
      ]
    },
    "utterance-content": {
      "patterns": [
        {
          "include": "#bullet-markers"
        },
        {
          "include": "#terminators"
        },
        {
          "include": "#annotations"
        },
        {
          "include": "#scoped-symbols"
        },
        {
          "include": "#retrace-markers"
        },
        {
          "include": "#actions"
        },
        {
          "include": "#pauses"
        },
        {
          "include": "#replacements"
        },
        {
          "include": "#omissions"
        },
        {
          "include": "#quotations"
        },
        {
          "include": "#words"
        }
      ]
    },
    "terminators": {
      "patterns": [
        {
          "name": "punctuation.terminator.chat",
          "match": "\\s+[.?!+](?=\\s|$)"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.postcode.chat",
          "match": "(\\[)(\\+|\\-)\\s*([a-z]{1,3})(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.begin.chat" },
            "2": { "name": "keyword.operator.postcode.chat" },
            "3": { "name": "entity.name.tag.postcode.chat" },
            "4": { "name": "punctuation.definition.annotation.end.chat" }
          }
        },
        {
          "name": "meta.annotation.explanation.chat",
          "match": "(\\[)(=!?)\\s*([^\\]]+)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.begin.chat" },
            "2": { "name": "keyword.operator.explanation.chat" },
            "3": { "name": "string.unquoted.explanation.chat" },
            "4": { "name": "punctuation.definition.annotation.end.chat" }
          }
        },
        {
          "name": "meta.annotation.paralinguistic.chat",
          "match": "(\\[)(%[a-z]{1,3}):(\\s*)([^\\]]+)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.begin.chat" },
            "2": { "name": "entity.name.tag.paralinguistic.chat" },
            "3": { "name": "punctuation.separator.chat" },
            "4": { "name": "string.unquoted.paralinguistic.chat" },
            "5": { "name": "punctuation.definition.annotation.end.chat" }
          }
        },
        {
          "name": "meta.annotation.ca.chat",
          "match": "(\\[)(\\^[a-z]{1,3})(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.begin.chat" },
            "2": { "name": "entity.name.tag.ca-marker.chat" },
            "3": { "name": "punctuation.definition.annotation.end.chat" }
          }
        },
        {
          "name": "meta.annotation.alternative.chat",
          "match": "(\\[)(:)(\\s*)([^\\]]+)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.begin.chat" },
            "2": { "name": "keyword.operator.alternative.chat" },
            "3": { "name": "punctuation.separator.chat" },
            "4": { "name": "string.unquoted.alternative.chat" },
            "5": { "name": "punctuation.definition.annotation.end.chat" }
          }
        },
        {
          "name": "meta.annotation.error.chat",
          "match": "(\\[)(\\*)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.begin.chat" },
            "2": { "name": "keyword.operator.error.chat" },
            "3": { "name": "punctuation.definition.annotation.end.chat" }
          }
        }
      ]
    },
    "scoped-symbols": {
      "patterns": [
        {
          "name": "meta.scoped.chat",
          "match": "(<)([^>]+)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.scoped.begin.chat" },
            "2": { "name": "string.unquoted.scoped-content.chat" },
            "3": { "name": "punctuation.definition.scoped.end.chat" }
          }
        }
      ]
    },
    "retrace-markers": {
      "patterns": [
        {
          "name": "meta.retrace.chat",
          "match": "(\\[)(/+|//\\?)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.retrace.begin.chat" },
            "2": { "name": "keyword.operator.retrace.chat" },
            "3": { "name": "punctuation.definition.retrace.end.chat" }
          }
        }
      ]
    },
    "actions": {
      "patterns": [
        {
          "name": "meta.action.chat",
          "match": "(&=)([a-z_]+)",
          "captures": {
            "1": { "name": "punctuation.definition.action.chat" },
            "2": { "name": "entity.name.function.action.chat" }
          }
        },
        {
          "name": "meta.action.event.chat",
          "match": "(&)([A-Z][a-z]*)",
          "captures": {
            "1": { "name": "punctuation.definition.event.chat" },
            "2": { "name": "entity.name.function.event.chat" }
          }
        }
      ]
    },
    "pauses": {
      "patterns": [
        {
          "name": "meta.pause.chat",
          "match": "(\\()([\\.\\d]+)(\\))",
          "captures": {
            "1": { "name": "punctuation.definition.pause.begin.chat" },
            "2": { "name": "constant.numeric.pause-duration.chat" },
            "3": { "name": "punctuation.definition.pause.end.chat" }
          }
        }
      ]
    },
    "replacements": {
      "patterns": [
        {
          "name": "meta.replacement.chat",
          "match": "\\[:\\s*([^\\]]+)\\]",
          "captures": {
            "1": { "name": "string.unquoted.replacement.chat" }
          }
        }
      ]
    },
    "omissions": {
      "patterns": [
        {
          "name": "meta.omission.chat",
          "match": "(0)([a-z]+)",
          "captures": {
            "1": { "name": "constant.numeric.omission-marker.chat" },
            "2": { "name": "variable.other.omission.chat" }
          }
        }
      ]
    },
    "quotations": {
      "patterns": [
        {
          "name": "meta.quotation.chat",
          "match": "\\[\"\\]",
          "captures": {
            "0": { "name": "keyword.operator.quotation-marker.chat" }
          }
        },
        {
          "name": "string.quoted.double.chat",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.chat",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "words": {
      "patterns": [
        {
          "name": "meta.word.untranscribed.chat",
          "match": "\\bxxx\\b",
          "captures": {
            "0": { "name": "constant.language.untranscribed.chat" }
          }
        },
        {
          "name": "meta.word.filler.chat",
          "match": "\\b(uh|um|mm|mhm)\\b",
          "captures": {
            "0": { "name": "entity.name.type.filler.chat" }
          }
        },
        {
          "name": "meta.word.compound.chat",
          "match": "([a-z]+)(\\+)([a-z]+)",
          "captures": {
            "1": { "name": "variable.other.word-part.chat" },
            "2": { "name": "keyword.operator.compound.chat" },
            "3": { "name": "variable.other.word-part.chat" }
          }
        }
      ]
    },
    "mor-content": {
      "patterns": [
        {
          "name": "meta.mor-word.chat",
          "match": "([a-z]+)(\\|)([^|\\s]+)",
          "captures": {
            "1": { "name": "entity.name.tag.mor-category.chat" },
            "2": { "name": "punctuation.separator.mor.chat" },
            "3": { "name": "variable.other.mor-stem.chat" }
          }
        },
        {
          "name": "punctuation.separator.mor-word.chat",
          "match": "\\s+"
        }
      ]
    },
    "gra-content": {
      "patterns": [
        {
          "name": "meta.gra-relation.chat",
          "match": "(\\d+)(\\|)(\\d+)(\\|)([A-Z]+)",
          "captures": {
            "1": { "name": "constant.numeric.gra-index.chat" },
            "2": { "name": "punctuation.separator.gra.chat" },
            "3": { "name": "constant.numeric.gra-head.chat" },
            "4": { "name": "punctuation.separator.gra.chat" },
            "5": { "name": "entity.name.tag.gra-relation.chat" }
          }
        },
        {
          "name": "punctuation.separator.gra-relation.chat",
          "match": "\\s+"
        }
      ]
    },
    "tier-content": {
      "patterns": [
        {
          "name": "string.unquoted.tier-content.chat",
          "match": ".+"
        }
      ]
    },
    "bullet-markers": {
      "patterns": [
        {
          "name": "constant.other.bullet.time.chat",
          "match": "\u2022\\d+_\\d+\u2022"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.chat",
          "match": "^%com:.*$"
        }
      ]
    }
  }
}
